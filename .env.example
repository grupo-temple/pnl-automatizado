# Copiá este archivo a .env.local y completá los valores
# Obtenés estos valores desde: https://supabase.com/dashboard → tu proyecto → Settings → API

# URL del proyecto Supabase (seguro exponer al cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon key (seguro exponer al cliente — RLS protege los datos)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NUNCA exponer al cliente. Solo usar en Server Actions.
# Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
